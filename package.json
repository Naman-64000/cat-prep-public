{
  "name": "cat-knowledge-vault",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "author": "CAT Knowledge Vault",
  "scripts": {
    "dev": "npm run build && concurrently \"npm:watch:renderer\" \"npm:start:electron\"",
    "start:electron": "wait-on dist/renderer/index.html && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "watch:renderer": "vite build --watch",
    "build:main": "tsc -p tsconfig.main.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.14.0",
    "dotenv": "^16.4.3",
    "electron": "^42.4.1",
    "katex": "^0.16.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.2",
    "rehype-katex": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron-builder": "^26.15.5",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.40",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.4",
    "vite": "^4.5.2",
    "wait-on": "^7.0.1"
  }
}
